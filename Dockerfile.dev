# ==========================================
# 第一阶段：构建阶段
# ==========================================
# 规范1：指定固定基础镜像版本，保证构建环境一致性
FROM golang:1.26-alpine AS builder

# 规范2：配置Go编译环境变量，启用Go Modules并配置国内代理
ENV GO111MODULE=on \
    GOPROXY=https://goproxy.cn,direct \
    CGO_ENABLED=0 \
    GOOS=linux \
    GOARCH=amd64

# 设置工作目录
WORKDIR /build

# 优化点：利用Docker分层缓存机制
# 优先复制依赖配置文件，依赖无变更时可复用缓存层，提升构建效率
COPY go.mod go.sum ./
RUN go mod download

# 复制项目全部源代码
COPY . .

# 编译项目，剔除调试符号减小二进制文件体积
RUN go build -ldflags="-s -w" -o im-server main.go

# ==========================================
# 第二阶段：运行阶段
# ==========================================
# 规范3：采用轻量化基础镜像，剥离编译环境，减小最终镜像体积
FROM alpine:3.18

# 镜像元信息
LABEL maintainer="YourName <your.email@example.com>"
LABEL description="LiteIM Backend Server"

# 安装必备依赖：时区数据、CA证书（支持HTTPS请求）
RUN apk --no-cache add tzdata ca-certificates && \
    cp /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone

WORKDIR /app

# 从构建阶段复制编译完成的二进制文件
COPY --from=builder /build/im-server /app/

# 安全规范：使用非root用户运行服务，降低容器安全风险
RUN adduser -S -D -H -h /app imuser

RUN mkdir -p /app/data/uploads /app/data/temp_chunks && \
    chown -R imuser:nobody /app && \
    chmod +x /app/im-server

USER imuser

# 声明服务端口
EXPOSE 8080

# 启动服务
CMD ["/app/im-server"]